# Environment variables for Hermes containers
# Copy this to ~/.config/hermes/env and fill in your values

# Vertex AI / GCP settings
ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
VERTEX_REGION=global
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=/secrets/vertex/application_default_credentials.json

# Dashboard authentication
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD_HASH=scrypt$16384$8$1$3GZNrC0huWWaVhRN19q4QQ==$zyVcsb7SA/EPutdBpUQoiAqAEZNnotN7dBOvv17n0QA=

# Discord integration (optional)
#DISCORD_BOT_TOKEN=your-bot-token
#DISCORD_ALLOWED_USERS=comma,separated,user,ids

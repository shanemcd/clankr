# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is gitignored and will never be committed.
#
# To create the vertex-credentials secret separately:
#   kubectl create namespace hermes-agent
#   kubectl create secret generic vertex-credentials \
#     -n hermes-agent \
#     --from-file=application_default_credentials.json=$HOME/.config/gcloud/application_default_credentials.json

apiVersion: v1
kind: Secret
metadata:
  name: hermes-env
  namespace: hermes-agent
type: Opaque
stringData:
  # Mounted at /opt/data/.env inside the container.
  # Hermes reads this file natively for all credentials.
  # Same format as ~/.hermes/.env on a local install.
  .env: |
    # LLM Provider (Vertex AI)
    ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
    GOOGLE_CLOUD_PROJECT=your-gcp-project-id
    VERTEX_REGION=global
    GOOGLE_CLOUD_LOCATION=global
    # ANTHROPIC_API_KEY=your-key  # if using Anthropic directly

    # Dashboard auth
    # Generate hash with:
    #   kubectl exec -n hermes-agent deploy/hermes-gateway -- \
    #     python -c "from plugins.dashboard_auth.basic import hash_password; print(hash_password('your-password'))"
    HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
    HERMES_DASHBOARD_BASIC_AUTH_PASSWORD_HASH=your-password-hash

    # Discord
    DISCORD_BOT_TOKEN=your-discord-bot-token
    DISCORD_ALLOWED_USERS=your-discord-user-id

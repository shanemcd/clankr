[Unit]
Description=Hermes Agent Gateway (Pod)
After=network-online.target
Wants=network-online.target

[Container]
Image=quay.io/shanemcd/hermes-agent:vertex-55742
ContainerName=hermes-gateway
Pod=hermes.pod

# Let s6-overlay handle gateway + dashboard supervision
Exec=sleep infinity

# Environment
Environment=HOME=/opt/data
EnvironmentFile=%h/.config/hermes/env

# Volumes
Volume=%h/.hermes:/opt/data:Z
Volume=%h/.config/gcloud/application_default_credentials.json:/secrets/vertex/application_default_credentials.json:z,ro

# Resource limits
Memory=2G

[Service]
# Restart policy
Restart=always

[Install]
WantedBy=default.target

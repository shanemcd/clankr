FROM localhost/nemoclaw-hermes:latest

ARG GITLAB_HOST=
ARG SIGNAL_HTTP_URL=
ARG SIGNAL_ACCOUNT=
ARG SIGNAL_ALLOWED_USERS=

USER root

# Install DuckDuckGo search, GitHub CLI, GitLab CLI, Google Workspace CLI, and jirahhh
RUN apt-get update -qq && apt-get install -y -qq --no-install-recommends \
      pandoc build-essential pkg-config libssl-dev protobuf-compiler \
      libclang-dev clang libz3-dev cmake && \
    rm -rf /var/lib/apt/lists/* && \
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | \
      CARGO_HOME=/opt/rust/cargo RUSTUP_HOME=/opt/rust/rustup sh -s -- -y --default-toolchain stable && \
    chmod -R a+rX /opt/rust && \
    uv pip install --python /opt/hermes/.venv/bin/python3 ddgs "jirahhh @ git+https://github.com/shanemcd/jirahhh.git" && \
    curl -sL https://github.com/cli/cli/releases/download/v2.96.0/gh_2.96.0_linux_amd64.tar.gz | \
    tar xz -C /usr/local --strip-components=1 && \
    curl -sL https://gitlab.com/api/v4/projects/gitlab-org%2Fcli/packages/generic/glab/1.107.0/glab_1.107.0_linux_amd64.tar.gz | \
    tar xz -C /usr/local/bin bin/glab --strip-components=1 && \
    npm install -g @googleworkspace/cli && \
    curl -sL https://mirror.openshift.com/pub/openshift-v4/clients/ocp/stable/openshift-client-linux-amd64-rhel8.tar.gz | \
    tar xz -C /usr/local/bin oc kubectl

# Extra CA certs for TLS interception proxy (e.g. internal GitLab)
# Create extra-ca-certs.pem from your internal CA chain, or use an empty file.
COPY extra-ca-certs.pem /tmp/extra-ca-certs.pem
RUN cat /tmp/extra-ca-certs.pem >> /etc/ssl/certs/ca-certificates.crt && \
    rm /tmp/extra-ca-certs.pem

# Git credential helpers (OpenShell proxy resolves placeholders at egress)
# Create glab-config.yml from glab-config.yml.example with your GitLab host.
COPY git-credential-openshell /usr/local/bin/git-credential-openshell
COPY glab-config.yml /sandbox/.config/glab-cli/config.yml
RUN chmod 755 /usr/local/bin/git-credential-openshell && \
    chown -R sandbox:sandbox /sandbox/.config/glab-cli && \
    chmod 600 /sandbox/.config/glab-cli/config.yml && \
    git config --system credential.https://github.com.helper 'openshell GITHUB_TOKEN' && \
    if [ -n "$GITLAB_HOST" ]; then \
      git config --system "credential.https://${GITLAB_HOST}.helper" 'openshell GITLAB_TOKEN'; \
    fi

# Google Workspace CLI (credentials use OpenShell placeholders, resolved at egress)
COPY gws-credentials.json /sandbox/.config/gws/credentials.json
RUN chown -R sandbox:sandbox /sandbox/.config/gws && \
    chmod 600 /sandbox/.config/gws/credentials.json

# Jirahhh config (placeholders resolved by proxy in Basic auth headers)
COPY jirahhh-config.yaml /sandbox/.config/jirahhh/config.yaml
RUN chown -R sandbox:sandbox /sandbox/.config/jirahhh && \
    chmod 600 /sandbox/.config/jirahhh/config.yaml

# Kubernetes/OpenShift config (token is an OpenShell placeholder, resolved at egress)
COPY kubeconfig /sandbox/.kube/config
RUN chown -R sandbox:sandbox /sandbox/.kube && \
    chmod 600 /sandbox/.kube/config

# Agent identity
COPY SOUL.md /sandbox/.hermes/SOUL.md

# Runtime config
COPY hermes.env /tmp/hermes.env
RUN cat /tmp/hermes.env >> /sandbox/.hermes/.env && \
    rm /tmp/hermes.env && \
    chown sandbox:sandbox /sandbox/.hermes/.env /sandbox/.hermes/SOUL.md

# Hermes settings and MCP servers (baked at build time)
COPY hermes-config.py /tmp/hermes-config.py
COPY update-config-hashes.py /tmp/update-config-hashes.py
ENV PATH="/opt/rust/cargo/bin:/opt/hermes/.venv/bin:$PATH" HOME=/sandbox \
    CARGO_HOME=/opt/rust/cargo RUSTUP_HOME=/opt/rust/rustup
RUN python3 /tmp/hermes-config.py && \
    chown sandbox:sandbox /sandbox/.hermes/config.yaml && \
    python3 /tmp/update-config-hashes.py && \
    rm /tmp/hermes-config.py /tmp/update-config-hashes.py

# Signal platform (set via --build-arg, persisted as ENV for os.getenv() discovery)
ENV SIGNAL_HTTP_URL=${SIGNAL_HTTP_URL} \
    SIGNAL_ACCOUNT=${SIGNAL_ACCOUNT} \
    SIGNAL_ALLOWED_USERS=${SIGNAL_ALLOWED_USERS}

USER sandbox

version: 1

filesystem_policy:
  read_only:
    - /usr
    - /lib
    - /etc
    - /opt/hermes
  read_write:
    - /sandbox
    - /opt/data
    - /tmp
    - /dev/null
    - /dev/urandom
    - /dev/pts

landlock:
  compatibility: best_effort

process:
  run_as_user: sandbox
  run_as_group: sandbox

network_policies:
  openrouter:
    name: openrouter
    endpoints:
      - host: openrouter.ai
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
    binaries:
      - path: /opt/hermes/.venv/bin/python

  duckduckgo:
    name: duckduckgo
    endpoints:
      - host: duckduckgo.com
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
      - host: "*.duckduckgo.com"
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
      - host: links.duckduckgo.com
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
    binaries:
      - path: /opt/hermes/.venv/bin/python

  github:
    name: github
    endpoints:
      - host: api.github.com
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
      - host: github.com
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
    binaries:
      - path: /opt/hermes/.venv/bin/python
      - path: /usr/bin/curl
      - path: /usr/local/bin/gh

  # Add your internal GitLab instance here. Use protocol: rest to enable
  # TLS interception and credential rewriting. Requires baking the internal
  # CA into the sandbox image (see Containerfile and extra-ca-certs.pem).
  #
  # gitlab_internal:
  #   name: gitlab-internal
  #   endpoints:
  #     - host: gitlab.internal.example
  #       port: 22
  #       enforcement: enforce
  #       access: full
  #     - host: gitlab.internal.example
  #       port: 443
  #       protocol: rest
  #       enforcement: enforce
  #       access: full
  #   binaries:
  #     - path: /opt/hermes/.venv/bin/python
  #     - path: /usr/bin/git
  #     - path: /usr/bin/ssh
  #     - path: /usr/bin/curl
  #           - path: /usr/local/bin/glab

  slack:
    name: slack
    endpoints:
      - host: "*.slack.com"
        port: 443
        protocol: websocket
        enforcement: enforce
        access: full
        websocket_credential_rewrite: true
      - host: slack.com
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
      - host: files.slack.com
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
    binaries:
      - path: /opt/hermes/.venv/bin/python

  nous:
    name: nous-research
    endpoints:
      - host: nousresearch.com
        port: 443
        enforcement: log
        access: full
      - host: hermes-agent.nousresearch.com
        port: 443
        enforcement: log
        access: full
    binaries:
      - path: /opt/hermes/.venv/bin/python

  pypi:
    name: pypi
    endpoints:
      - host: pypi.org
        port: 443
        protocol: rest
        enforcement: log
        access: full
      - host: files.pythonhosted.org
        port: 443
        enforcement: log
        access: full
    binaries:
      - path: /opt/hermes/.venv/bin/python
      - path: /usr/local/bin/pip3

DISCORD_ALLOWED_USERS=your-discord-user-id
_HERMES_FORCE_GITHUB_TOKEN=openshell:resolve:env:GITHUB_TOKEN
_HERMES_FORCE_GH_TOKEN=openshell:resolve:env:GITHUB_TOKEN
GITHUB_SHANEMCD_READONLY_TOKEN=openshell:resolve:env:GITHUB_READONLY_TOKEN
ANTHROPIC_API_KEY=openshell:resolve:env:ANTHROPIC_API_KEY
ANTHROPIC_BASE_URL=https://inference.local
GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND=file
GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=/sandbox/.config/gws/credentials.json
SIGNAL_HTTP_URL=http://host.containers.internal:8081
SIGNAL_ACCOUNT=+your-phone-number
SIGNAL_ALLOWED_USERS=+your-phone-number
